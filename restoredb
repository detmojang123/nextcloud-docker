#!/bin/bash
# Restore the PostgreSQL database after a disaster.

# Load variables from .env to get credentials
export $(grep -v '^#' .env | xargs)

BACKUP_FILE=$1

# 2. Check if filename was provided
if [ -z "$BACKUP_FILE" ]; then
    echo "Usage: $0 path/to/backup_file.sql.gz (or .sql)"
    exit 1
fi

# 3. Check if file exists
if [ ! -f "$BACKUP_FILE" ]; then
    echo "Error: Backup file '$BACKUP_FILE' not found."
    exit 1
fi

# Use the Postgres DB variable for the warning message
echo "Warning: This will overwrite the current '$POSTGRES_DB' database!"
read -p "Are you sure you want to proceed? (y/n) " -n 1 -r
echo
if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    echo "Restore cancelled."
    exit 1
fi

echo "Starting restore from $BACKUP_FILE..."

# 4. Handle compressed vs raw .sql files
# We use psql for restores. -v ON_ERROR_STOP=1 ensures the script fails
# if the SQL contains errors.
if [[ "$BACKUP_FILE" == *.gz ]]; then
    gunzip -c "$BACKUP_FILE" | docker exec -i -e PGPASSWORD="$POSTGRES_PASSWORD" ${BASENAME}-db \
    psql -U "$POSTGRES_USER" -d "$POSTGRES_DB" -v ON_ERROR_STOP=1
else
    cat "$BACKUP_FILE" | docker exec -i -e PGPASSWORD="$POSTGRES_PASSWORD" ${BASENAME}-db \
    psql -U "$POSTGRES_USER" -d "$POSTGRES_DB" -v ON_ERROR_STOP=1
fi

# 5. Check result
if [ $? -eq 0 ]; then
    echo "Success: Database restored."
    echo "It's recommended to restart the app container now: docker restart ${BASENAME}"
else
    echo "Error: Restore failed!"
    exit 1
fi
